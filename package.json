{
  "name": "smart-tech",
  "version": "2.0.43",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mobile": "vite --host",
    "build": "tsc && vite build",
    "build:prod": "tsc --noEmit && vite build --mode production",
    "preview": "vite preview",
    "preview:prod": "vite preview --mode production",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run build",
    "lint": "eslint \"src/**/*.{ts,tsx}\" vite.config.ts --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" vite.config.ts --fix",
    "icons:pwa": "node scripts/generate-pwa-icons.mjs",
    "icons:pro": "node scripts/generate-pwa-icons-pro.mjs",
    "verify:pwa": "node scripts/verify-pwa-icons.mjs",
    "icons:all": "npm run icons:pwa && npm run verify:pwa",
    "screenshots:pwa": "node scripts/generate-pwa-screenshots.mjs",
    "prebuild": "node scripts/generate-version-json.mjs && node scripts/generate-changelog.mjs",
    "dev:desktop": "vite --mode desktop",
    "build:desktop": "npm run prebuild && tsc && vite build --mode desktop",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --config src-tauri/tauri.prod.conf.json",
    "update:package": "node tools/update/build-update-package.mjs",
    "sync:tauri-version": "node scripts/sync-tauri-version.mjs",
    "pretauri:dev": "npm run sync:tauri-version",
    "pretauri:build": "npm run sync:tauri-version",
    "release:desktop": "node scripts/release-desktop.mjs",
    "release:desktop:signed": "node scripts/release-desktop.mjs --require-feed",
    "sales:build": "npm run build:desktop && npm run tauri:build",
    "release:check": "node scripts/release-readiness.mjs",
    "qa:e2e:release": "playwright test tests/e2e/smoke.spec.ts tests/e2e/system-tests.spec.ts tests/e2e/release-critical-flows.spec.ts",
    "release:qa": "npm run release:check && npm run type-check && npm run qa:e2e:release",
    "release:desktop:qa": "npm run release:check && npm run build:desktop && npm run qa:e2e:release",
    "qa:unit:finance": "vitest run tests/unit/finance-calc-regression.test.ts",
    "qa:e2e:matrix": "playwright test tests/e2e/qa-master-routes.spec.ts tests/e2e/qa-master-chaos.spec.ts --project=chromium --workers=1 --reporter=line",
    "qa:master": "npm run release:check && npm run type-check && npm run qa:unit:finance && npm run qa:e2e:release && npm run qa:e2e:matrix",
    "qa:master:desktop": "npm run release:check && npm run build:desktop && npm run qa:unit:finance && npm run qa:e2e:release && npm run qa:e2e:matrix",
    "qa:e2e:stress": "playwright test tests/e2e/stress-tabs-reopen.spec.ts tests/e2e/failure-probes.spec.ts --project=chromium --workers=1 --reporter=line",
    "qa:e2e:collect": "playwright test tests/e2e/smoke.spec.ts tests/e2e/release-critical-flows.spec.ts tests/e2e/stress-tabs-reopen.spec.ts tests/e2e/failure-probes.spec.ts --project=chromium --workers=1 --reporter=line,html",
    "qa:all": "npm run qa:unit:finance && npm run qa:e2e:release && npm run qa:e2e:matrix && npm run qa:e2e:stress",
    "cleanup:desktop-legacy:dry": "node scripts/clean-desktop-offline-legacy.mjs --dry-run",
    "cleanup:desktop-legacy": "node scripts/clean-desktop-offline-legacy.mjs",
    "check:desktop-offline-clean": "node scripts/check-desktop-offline-clean.mjs",
    "build:desktop:clean": "npm run build:desktop && npm run check:desktop-offline-clean",
    "cleanup:ui-legacy:dry": "node scripts/clean-ui-legacy.mjs --dry-run",
    "cleanup:ui-legacy": "node scripts/clean-ui-legacy.mjs",
    "cleanup:online-legacy:dry": "node scripts/clean-online-legacy.mjs --dry-run",
    "cleanup:online-legacy": "node scripts/clean-online-legacy.mjs",
    "cleanup:print-legacy:dry": "node scripts/clean-print-legacy.mjs --dry-run",
    "cleanup:print-legacy": "node scripts/clean-print-legacy.mjs",
    "check:desktop-weight": "node scripts/check-desktop-weight.mjs",
    "build:desktop:lean": "npm run build:desktop && npm run check:desktop-offline-clean && npm run check:desktop-weight",
    "check:zero-skeleton": "node scripts/check-zero-skeleton.mjs",
    "check:classic-desktop": "node scripts/check-classic-desktop.mjs",
    "check:classic-refine": "node scripts/check-classic-refine.mjs",
    "check:instant-navigation": "node scripts/check-instant-navigation.mjs",
    "check:no-flicker-navigation": "node scripts/check-no-flicker-navigation.mjs",
    "check:sora-font-system": "node scripts/check-sora-font-system.mjs",
    "check:backup-compact-diagnostics": "node scripts/check-backup-compact-diagnostics.mjs",
    "check:system-notices": "node scripts/check-system-notices.mjs",
    "check:regression-persistence-finance": "node scripts/check-regression-persistence-finance.mjs",
    "check:notice-badges-resolution": "node scripts/check-notice-badges-resolution.mjs",
    "check:sidebar-profile-brand": "node scripts/check-sidebar-profile-brand.mjs",
    "check:typecheck-hotfix-p37": "node scripts/check-typecheck-hotfix-p37.mjs",
    "tauri:build:signed-updater": "node scripts/build-tauri-signed-updater.mjs",
    "check:tauri-updater-config-p38": "node scripts/check-tauri-updater-config-p38.mjs",
    "tauri:build:signed-msi": "node scripts/build-msi-signed-auto.mjs",
    "release:msi:signed:auto": "node scripts/build-msi-signed-auto.mjs --release",
    "release:msi:signed-updater:auto": "node scripts/build-msi-signed-auto.mjs --release --with-updater",
    "check:msi-signed-auto-p39": "node scripts/check-msi-signed-auto-p39.mjs",
    "check:desktop-no-supabase": "node scripts/check-desktop-no-supabase.mjs",
    "release:admin:signed": "node scripts/release-admin-signed.mjs",
    "release:auto": "node scripts/release-auto-version-tag.mjs",
    "release:auto:patch": "node scripts/release-auto-version-tag.mjs --patch",
    "release:auto:dry": "node scripts/release-auto-version-tag.mjs --patch --dry-run",
    "check:release-auto-version-tag": "node scripts/check-release-auto-version-tag.mjs",
    "cloudflare:update:prepare": "node scripts/generate-tauri-latest-json.mjs",
    "release:cloudflare:update": "node scripts/publish-cloudflare-update.mjs",
    "check:cloudflare-update-feed": "node scripts/check-cloudflare-update-feed.mjs"
  },
  "dependencies": {
    "@razein97/tauri-plugin-rusqlite2": "^2.2.7",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-log": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "dexie": "^4.3.0",
    "jszip": "^3.10.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.28.0",
    "react-window": "^2.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/trusted-types": "^2.0.7",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "sharp": "^0.33.5",
    "terser": "^5.31.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "eslint": "^9.22.0",
    "@eslint/js": "^9.22.0",
    "typescript-eslint": "^8.26.1",
    "globals": "^15.15.0"
  }
}
